{
  "name": "raddigo-root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "bun --filter './apps/*-service' dev",
    "dev:admin": "cd apps/admin-panel && ~/.bun/bin/bun run dev",
    "start": "docker compose -f docker-compose.yml up --build",
    "docker:dev": "docker-compose up --build",
    "docker:dev:detach": "docker-compose up --build -d",
    "docker:dev:logs": "docker-compose logs -f",
    "docker:dev:stop": "docker-compose down",
    "docker:dev:clean": "docker-compose down -v --rmi all",
    "docker:prod": "docker-compose up --build -d",
    "docker:prod:stop": "docker-compose down",
    "docker:prod:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:build:prod": "docker-compose build",
    "docker:health": "docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'",
    "docker:prune": "docker system prune -af && docker volume prune -f"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^7.0.12",
    "mysql2": "^3.9.7",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "bun-types": "^1.3.5"
  }
}