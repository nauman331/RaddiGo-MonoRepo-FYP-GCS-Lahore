# Production Environment Variables
# Copy this file to .env.production and update values for production

# Database Configuration
DB_HOST=your-production-db-host
DB_PORT=25060
DB_NAME=raddigo_prod
DB_USER=your-production-db-user
DB_PASSWORD=your-production-db-password
DB_SSL_MODE=REQUIRED

# Service Ports
GATEWAY_PORT=3001
AUTH_PORT=3002
CATEGORY_PORT=3003
ORDER_PORT=3004

# JWT Configuration
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-for-production
JWT_EXPIRES_IN=7d

# Email Configuration
NODEMAILER_PASS=your-production-email-password
NODEMAILER_USER=your-production-email@example.com
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587

# Redis Configuration
REDIS_URL=rediss://your-production-redis-url

# Location Configuration
RADIUS_KM=50

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-production-firebase-project
FIREBASE_CLIENT_EMAIL=your-production-firebase-email
FIREBASE_PRIVATE_KEY="your-production-firebase-private-key"